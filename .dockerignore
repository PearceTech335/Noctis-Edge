# Python runtime artefacts
.venv/
__pycache__/
*.pyc
*.pyo

# Git internals (not needed inside image)
.git/

# Submodule dirs — cloned fresh during build for reproducibility
nikto/
# Exclude cve-offline directory but keep the pre-built CSV for the Docker image
CVE/cve-offline/
!CVE/cve-offline/cve-summary.csv

# Raw NVD CVE JSON files — not used at runtime (container uses cve-offline CSV instead)
# Excluding this saves ~200 MB of build context transfer time
CVE/cve/

# Runtime output
sessions/
session.json
nikto_*.txt

# Per-user secrets / config — mounted as volume at runtime
noctis.conf
cve_knowledge_base.json

# OS noise
.DS_Store
Thumbs.db
*.swp
*.swo

# IDE config
.idea/
.vscode/
.continue/
