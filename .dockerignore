sessions/
session.json
nikto_*.txt

# Per-user secrets / config — mounted as volume at runtime
noctis.conf
cve_knowledge_base.json

# OS noise
.DS_Store
Thumbs.db
*.swp
*.swo

# IDE config
.idea/
.vscode/
.continue/
