nikto_*.txt

# Database files
reconotron.db
*.db
*.sqlite

# Noctis Edge local config — may contain git tokens; never commit
.noctis_config

# Tool manifest — subscriber artifact delivered via update.sh; never commit
tool_manifest.json
noctis.conf

# Tool performance knowledge base — runtime-generated, machine-specific
tool_knowledge_base.json

# Internal planning and setup files — not for public distribution
ForYouToDo.md
.codex
