# Subscriber-only / operator tool manifest scripts — delivered via paid update channel
scripts/build_tool_manifest.py
scripts/add_tool_manifest.py
scripts/submit_tool_manifest.py

# Tool manifest backup — created when update.sh overwrites with a new subscriber download
tool_manifest.json.bak

# Docker build artefact — not source
build.log

