CVE/cve/
CVE/cve-offline/

# NVD incremental download cache — large intermediate JSON files
CVE/.nvd-cache/

# Offline threat-intelligence databases — rebuilt by setup.sh / update.sh, not source
CVE/epss-scores.csv
CVE/nvd-cvss.csv

# Development / quarantine scratch area — not for distribution
quarantine/


# Scan session data (runtime output — not source code)
sessions/
session.json

