# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.venv/
venv/

# Large wordlists (not needed — program uses system SecLists)
WordLists/rockyou.txt

# CVE Knowledge Base (JSON file - machine specific accumulated data)
cve_knowledge_base.json

# CVE database (57 MB CSV — regenerate with CVE/cve-offline/updatecsv.sh)
CVE/cve-offline/cve-summary.csv

# Embedded git repos — cloned at runtime by setup.sh, not tracked
CVE/cve/
CVE/cve-offline/


# Scan session data (runtime output — not source code)
sessions/
session.json

# Nikto scan output files (nikto/ directory is the bundled submodule — do NOT ignore it)
nikto_*.txt

# Database files
reconotron.db
*.db
*.sqlite

# Noctis Edge local config — may contain git tokens; never commit
.noctis_config
noctis.conf

