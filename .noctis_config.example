# =============================================================================
#  Noctis Edge — Community KB Configuration
#
#  Copy this file to .noctis_config and fill in your settings:
#    cp .noctis_config.example .noctis_config
#
#  .noctis_config is gitignored — it will NOT be committed or shared.
#  Keep it secure, especially if you store a token below.
# =============================================================================

# Your account tier: "free" (default) or "paid"
# Paid-tier users receive the curated community KB on every ./update.sh run.
TIER=free

# -----------------------------------------------------------------------------
# Community KB submission (all users)
# -----------------------------------------------------------------------------
# Remote URL for the KB submissions repo.
# Your local cve_knowledge_base.json is pushed here on every ./update.sh
# so the maintainer can review and curate LLM-generated probe scripts.
#
# Obtain this URL from: https://github.com/PearceTech335/noctis-edge-kb-submissions
KB_SUBMIT_REMOTE=https://github.com/PearceTech335/noctis-edge-kb-submissions.git

# -----------------------------------------------------------------------------
# Curated community KB pull (paid tier only)
# -----------------------------------------------------------------------------
# Remote URL for the read-only curated community KB.
# Paid users pull proven scripts from the community on every ./update.sh.
KB_COMMUNITY_REMOTE=https://github.com/PearceTech335/noctis-edge-kb-community.git

# -----------------------------------------------------------------------------
# Git authentication — HTTPS token (optional)
# -----------------------------------------------------------------------------
# If you have SSH keys configured for GitHub, leave KB_SUBMIT_TOKEN empty.
#
# For HTTPS access, create a GitHub fine-grained Personal Access Token with:
#   Repository: noctis-edge-kb-submissions
#   Permissions: Contents — Read and write
#
# Then paste it below.  Never share this file or commit it to git.
#
# KB_SUBMIT_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
